{
  "name": "open-volunteer-mcp-node",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Example MCP server that exposes the Open Volunteer demo tools using the official TypeScript SDK.",
  "scripts": {
    "build": "tsc",
    "dev:express": "tsx watch --inspect index.local.js",
    "dev:mcp-sdk": "USE_MCP_SDK=true tsx watch --inspect index.local.js",
    "inspect": "npx @modelcontextprotocol/inspector",
    "cloud:zip": "./aws/zip-function.sh",
    "cloud:up": "./aws/cloud-up.sh --stage=staging",
    "cloud:up:prod": "./aws/cloud-up.sh --stage=prod",
    "cloud:update": "./aws/cloud-update.sh --stage=staging",
    "cloud:update:prod": "./aws/cloud-update.sh --stage=prod",
    "cloud:down": "./aws/cloud-down.sh --stage=staging",
    "cloud:down:prod": "./aws/cloud-down.sh --stage=prod",
    "cloud:results": "node aws/write-formation-results.js --stage=staging",
    "cloud:results:prod": "node aws/write-formation-results.js --stage=prod"
  },
  "dependencies": {
    "@agentic-profile/a2a-mcp-express": "^0.7.3",
    "@codegenie/serverless-express": "^4.17.1",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "loglevel": "^1.9.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
